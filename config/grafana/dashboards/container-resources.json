{
  "title": "Container Resources (cAdvisor)",
  "uid": "container-resources",
  "schemaVersion": 39,
  "version": 1,
  "editable": true,
  "time": { "from": "now-15m", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "CPU usage per container (cores)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "sum by (name) (rate(container_cpu_usage_seconds_total{name!=\"\"}[1m]))",
          "legendFormat": "{{name}}"
        }
      ]
    },
    {
      "id": 2,
      "title": "Memory usage per container",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "bytes" }, "overrides": [] },
      "targets": [
        {
          "expr": "container_memory_usage_bytes{name!=\"\"}",
          "legendFormat": "{{name}}"
        }
      ]
    },
    {
      "id": 3,
      "title": "Network receive bytes/s per container",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "fieldConfig": { "defaults": { "unit": "Bps" }, "overrides": [] },
      "targets": [
        {
          "expr": "sum by (name) (rate(container_network_receive_bytes_total{name!=\"\"}[1m]))",
          "legendFormat": "{{name}}"
        }
      ]
    },
    {
      "id": 4,
      "title": "Containers reporting to cAdvisor",
      "type": "stat",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        { "expr": "count(count by (name) (container_last_seen{name!=\"\"}))" }
      ]
    }
  ]
}

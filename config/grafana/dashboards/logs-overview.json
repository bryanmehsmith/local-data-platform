{
  "title": "Logs Overview (Loki)",
  "uid": "logs-overview",
  "schemaVersion": 39,
  "version": 1,
  "editable": true,
  "time": { "from": "now-15m", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "container",
        "type": "query",
        "datasource": { "type": "loki", "uid": "Loki" },
        "query": "label_values(container)",
        "refresh": 2,
        "includeAll": true,
        "multi": true
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Log lines/min by container",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 0 },
      "datasource": { "type": "loki", "uid": "Loki" },
      "targets": [
        {
          "expr": "sum by (container) (count_over_time({container=~\"$container\"}[1m]))"
        }
      ]
    },
    {
      "id": 2,
      "title": "All logs",
      "type": "logs",
      "gridPos": { "h": 12, "w": 24, "x": 0, "y": 8 },
      "datasource": { "type": "loki", "uid": "Loki" },
      "targets": [
        { "expr": "{container=~\"$container\"}" }
      ]
    },
    {
      "id": 3,
      "title": "Likely errors",
      "type": "logs",
      "gridPos": { "h": 12, "w": 24, "x": 0, "y": 20 },
      "datasource": { "type": "loki", "uid": "Loki" },
      "targets": [
        { "expr": "{container=~\"$container\"} |~ \"(?i)error\"" }
      ]
    }
  ]
}

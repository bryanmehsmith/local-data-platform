# Copy this file to .env and fill in real values. .env is gitignored.
# NOTE: Docker Compose interpolates .env values (both as the project env file and
# via env_file:). A literal `$` in a secret must be escaped as `$$`, otherwise
# Compose treats it as a variable reference and can silently drop the value.

# --- MinIO ---
MINIO_ROOT_USER=admin
MINIO_ROOT_PASSWORD=change-me-please
# App credentials created by minio-init (used by Trino/Nessie instead of root)
MINIO_APP_ACCESS_KEY=ldp-app
MINIO_APP_SECRET_KEY=change-me-too

# --- Nessie ---
# Default is now JDBC (Postgres-backed) so catalog history survives a
# container restart; set to IN_MEMORY only for throwaway/test stacks.
NESSIE_VERSION_STORE_TYPE=JDBC
NESSIE_PG_USER=nessie
NESSIE_PG_PASSWORD=changeme-nessie
NESSIE_PG_DB=nessie

# --- Dagster ---
DAGSTER_HOME=/opt/dagster/dagster_home

# --- Redpanda ---
REDPANDA_BROKER=redpanda:9092

# --- Ollama ---
OLLAMA_CHAT_MODEL=llama3.2:3b
OLLAMA_EMBED_MODEL=nomic-embed-text

# --- Open WebUI ---
WEBUI_SECRET_KEY=change-me-too-please
OPENWEBUI_PIPELINES_API_KEY=0p3n-w3bu!

# --- Qdrant ---
QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION=curated_events
QDRANT_DOCS_COLLECTION=dbt_docs

# --- RAG pipeline ---
RAG_TOP_K=5

# --- Metabase ---
METABASE_ADMIN_EMAIL=admin@local.platform
METABASE_ADMIN_PASSWORD=change-me-metabase-admin

# --- Text-to-SQL pipeline ---
TRINO_READONLY_USER=text_to_sql_readonly
TRINO_CATALOG=iceberg

# --- Backend API's own read-only Trino queries (/api/trino/query) ---
# Enforced read-only at the Trino file-based access-control layer too —
# see config/trino/access-control/rules.json.
TRINO_BACKEND_READONLY_USER=backend_readonly

# --- Observability ---
GRAFANA_ADMIN_PASSWORD=change-me-grafana-admin

# --- Backend / Frontend app ---
# The backend now compares a hash of the X-API-Key header against
# BACKEND_API_KEY_HASHES (comma-separated) instead of a plaintext secret —
# see backend/app/security.py. Generate a hash with:
#   python -c "import hashlib,hmac; p=b'ldp-backend-api-key-pepper-v1'; \
#   print(hmac.new(p, b'<your-key>', hashlib.sha256).hexdigest())"
# List multiple hashes (comma-separated) to rotate keys without downtime:
# add the new hash, redeploy, switch callers to the new plaintext key, then
# drop the old hash.
BACKEND_API_KEY_HASHES=
# Legacy plaintext fallback — only used if BACKEND_API_KEY_HASHES is unset.
# The frontend build also reads this directly (see docker-compose.app.yml).
BACKEND_API_KEY=change-me-backend-api-key
